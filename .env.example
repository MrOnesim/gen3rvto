# === Base de données (Supabase Postgres) ===
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres"

# === Supabase Auth (tableau de bord admin) ===
# Récupérez ces valeurs dans Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre-anon-key"
# (optionnel, pour les opérations serveur privilégiées)
SUPABASE_SERVICE_ROLE_KEY="votre-service-role-key"

# === Umami (analytiques / vues du site) ===
# Créez un site dans Umami, récupérez l'ID et générez un token API (Settings > API Keys)
NEXT_PUBLIC_UMAMI_ID="votre-website-id-umami"
NEXT_PUBLIC_UMAMI_SRC="https://analytics.umami.cloud/script.js"
UMAMI_API_TOKEN="votre-token-api-umami"
UMAMI_SITE_ID="votre-website-id-umami"
UMAMI_URL="https://api.umami.cloud"
